# ===== DATABASE CONFIGURATION (NeonDB) =====
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# ===== TAP ACADEMY API CONFIGURATION =====
# TAP_ACADEMY_EMAIL=
# TAP_ACADEMY_PASSWORD=
TAP_ACADEMY_EMAIL=
TAP_ACADEMY_PASSWORD=
TAP_ACADEMY_URL=
TAP_ACADEMY_JOB_LIMIT=

# ===== GMAIL SMTP CONFIGURATION =====
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=
MAIL_SMTP_AUTH=
MAIL_SMTP_STARTTLS_ENABLE=

# ===== APPLICATION SERVER CONFIGURATION =====
SERVER_PORT=8080
SERVER_CONTEXT_PATH=
SERVER_ERROR_INCLUDE_MESSAGE=

# ===== LOGGING CONFIGURATION =====
LOG_LEVEL_COM_JOB_JOBALERTS=DEBUG
LOG_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOG_LEVEL_ORG_HIBERNATE=WARN

# ===== JPA / HIBERNATE CONFIGURATION =====
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

# ===== CONNECTION POOL SETTINGS =====
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=30000
DB_MAX_LIFETIME=600000
DB_IDLE_TIMEOUT=600000

